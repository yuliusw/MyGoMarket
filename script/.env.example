# PostgreSQL
POSTGRES_USER=rpa_app
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=RPA

# MinIO
MINIO_ROOT_USER=rpa_minio_access_key
MINIO_ROOT_PASSWORD=change-me-minio-secret-key

# Grafana
GF_SECURITY_ADMIN_USER=rpa_admin
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-admin-password

# App feature toggles
FEATURES_JWT_AUTH=false
FEATURES_CASBIN_AUTHZ=false
FEATURES_AUTH_BYPASS_USER_ID=00000000-0000-0000-0000-000000000001
FEATURES_RATE_LIMIT_ENABLED=true
FEATURES_RATE_LIMIT_RATE=5
FEATURES_RATE_LIMIT_CAPACITY=10
FEATURES_RATE_LIMIT_LIMIT=100
FEATURES_REQUEST_POOL_ENABLED=true
FEATURES_REQUEST_POOL_CAPACITY=1000
