[request_definition]

# 请求：用户，团体(域)，权限标识

r = sub, dom, obj



[policy_definition]

# 策略：角色，权限标识

p = sub, obj



[role_definition]

# 角色继承：用户，角色，团体(域)

g = _, _, _



[policy_effect]

# 只要有一条策略允许即通过

e = some(where (p.eft == allow))



[matchers]

# 匹配规则：请求用户在请求域中拥有某个角色，且该角色拥有请求权限

m = g(r.sub, p.sub, r.dom) && r.obj == p.obj
